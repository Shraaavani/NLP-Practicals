#Perform text cleaning, perform lemmatization (any method), remove stop words (any method), label encoding. Create representations using TF-IDF. Save outputs. 

import pandas as pd
import nltk
import re
from nltk.corpus import stopwords
from nltk.stem import WordNetLemmatizer
from sklearn.preprocessing import LabelEncoder
from sklearn.feature_extraction.text import TfidfVectorizer

# 1. Setup & Downloads (run once)
nltk.download('stopwords')
nltk.download('wordnet')
nltk.download('omw-1.4')

# Sample Data
data = {
    'text': [
        "The programmers are coding @AI_Lab! They love Python.",
        "Eating healthy food and fruits is great for your body.",
        "Machine learning models require clean data and coding.",
        "Fresh apples and oranges are very healthy fruits."
    ],
    'category': ['Tech', 'Health', 'Tech', 'Health']
}

df = pd.DataFrame(data)

# 2. Text Cleaning
stop_words = set(stopwords.words('english'))
lemmatizer = WordNetLemmatizer()

def clean_text(text):
    # Remove special characters
    text = re.sub(r'[^\w\s]', '', text)
    text = text.lower()

    tokens = text.split()

    # Remove stopwords + Lemmatize
    cleaned_tokens = [
        lemmatizer.lemmatize(word)
        for word in tokens
        if word not in stop_words
    ]

    return " ".join(cleaned_tokens)

df['cleaned_text'] = df['text'].apply(clean_text)

# 3. Label Encoding
label_encoder = LabelEncoder()
df['category_encoded'] = label_encoder.fit_transform(df['category'])

# 4. TF-IDF
tfidf_vec = TfidfVectorizer()
tfidf_matrix = tfidf_vec.fit_transform(df['cleaned_text'])

df_tfidf = pd.DataFrame(
    tfidf_matrix.toarray(),
    columns=tfidf_vec.get_feature_names_out()
)

# 5. Save Outputs
df.to_csv('processed_data.csv', index=False)
df_tfidf.to_csv('tfidf_features.csv', index=False)

# Output
print("--- Original & Cleaned Data ---")
print(df[['text', 'cleaned_text', 'category_encoded']])

print("\n--- TF-IDF Feature Matrix ---")
print(df_tfidf.head())

print("\n✅ Success: Files saved (processed_data.csv, tfidf_features.csv)")
